---
import { ArrowUpRight, Mail } from "lucide-react"

import { ButtonLink } from "@/components/ButtonLink"
---

<header
  class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 lg:px-8"
>
  <a href="/" class="group inline-flex items-center gap-3" aria-label="Home">
    <span
      class="flex size-9 items-center justify-center rounded-lg bg-primary text-sm font-semibold text-primary-foreground"
      aria-hidden="true"
    >
      CB
    </span>
    <span class="flex flex-col leading-none">
      <span class="font-heading text-sm font-medium">Christian Barra</span>
      <span class="text-xs text-muted-foreground">Engineer / Founder</span>
    </span>
  </a>

  <nav
    class="hidden items-center gap-1 sm:flex"
    aria-label="Primary navigation"
  >
    <ButtonLink href="#projects" variant="ghost" size="sm">Projects</ButtonLink>
    <ButtonLink
      href="https://www.linkedin.com/in/christianbarra/"
      target="_blank"
      rel="noreferrer"
      variant="ghost"
      size="sm"
    >
      LinkedIn
      <ArrowUpRight data-icon="inline-end" />
    </ButtonLink>
    <ButtonLink href="mailto:me@christianbarra.com" size="sm">
      <Mail data-icon="inline-start" />
      Email
    </ButtonLink>
  </nav>
</header>
