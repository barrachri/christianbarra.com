---
import { Separator } from "@/components/ui/separator"
---

<footer class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-6 py-10 lg:px-8">
  <Separator />
  <div
    class="flex flex-col justify-between gap-4 text-sm text-muted-foreground sm:flex-row sm:items-center"
  >
    <p>CC BY-SA 4.0</p>
    <div class="flex flex-wrap items-center gap-4">
      <a class="hover:text-foreground" href="mailto:me@christianbarra.com"
        >Email</a
      >
      <a
        class="hover:text-foreground"
        href="https://www.linkedin.com/in/christianbarra/"
        target="_blank"
        rel="noreferrer"
      >
        LinkedIn
      </a>
      <a
        class="hover:text-foreground"
        href="https://twitter.com/christianbarra"
        target="_blank"
        rel="noreferrer"
      >
        Twitter
      </a>
    </div>
  </div>
</footer>
