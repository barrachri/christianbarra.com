---
import BaseLayout from "@/layouts/BaseLayout.astro"
---

<BaseLayout
  title="Page not found | Christian Barra"
  description="The page you are looking for does not exist."
>
  <main
    class="mx-auto flex min-h-screen w-full max-w-3xl items-center px-6 py-12 sm:py-16 lg:px-8"
  >
    <section class="flex flex-col gap-5">
      <p
        class="font-mono text-sm tracking-[0.22em] text-muted-foreground uppercase"
      >
        404
      </p>
      <h1
        class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl"
      >
        Page not found.
      </h1>
      <p class="max-w-2xl text-lg leading-8 text-muted-foreground">
        This page is not here anymore. The site is intentionally simple now.
      </p>
      <a
        href="/"
        class="font-medium underline decoration-border underline-offset-4 hover:text-muted-foreground"
      >
        Back home
      </a>
    </section>
  </main>
</BaseLayout>
