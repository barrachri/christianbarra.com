---
import "@/styles/global.css"

type Props = {
  title?: string
  description?: string
}

const siteTitle = "Christian Barra"
const defaultTitle = "Christian Barra: Software Engineer, Sailor & Founder"
const defaultDescription =
  "Software engineer, sailor and founder building and buying durable companies across SaaS and traditional businesses."

const { title = defaultTitle, description = defaultDescription } = Astro.props
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://www.christianbarra.com"
)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteTitle} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#111111" />

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@christianbarra" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <slot />

    <script>
      if (import.meta.env.DEV) {
        import("react-grab")
      }
    </script>
  </body>
</html>
